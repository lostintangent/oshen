#!../../zig-out/bin/oshen
# Shell benchmark: loops, functions, conditionals, globs, builtins

fun process_file
    if test $(calc $count % 2) -eq 0
        set count $(calc $count + 2)
    else
        increment count
    end
end

var i 0
while test $i -lt 100
    set count 0
    each f in /usr/bin/*
        process_file
    end
    increment i
end
