#!/usr/bin/env elvish
# Shell benchmark: loops, functions, conditionals, globs, builtins

var count = 0

fn process-file {
    if (eq (% $count 2) 0) {
        set count = (+ $count 2)
    } else {
        set count = (+ $count 1)
    }
}

var i = 0
while (< $i 100) {
    set count = 0
    for f [/usr/bin/*] {
        process-file
    }
    set i = (+ $i 1)
}
